# =============================================================================
# Ryvo Network — local environment template
# =============================================================================
# Copy this file to `.env` and fill in the values you need. The deploy and
# demo scripts read these via shell env, so you can also export them directly
# instead of using `.env`. None of the keys below are committed.

# -----------------------------------------------------------------------------
# Deployer wallets (required by `npm run setup:wallet` / `scripts/setup-wallet.sh`)
# -----------------------------------------------------------------------------
# Phantom-style base58 secret keys. The setup script converts these into
# `keys/devnet-deployer.json` / `keys/mainnet-deployer.json` (Solana JSON-array
# format) and points Anchor.toml at the resulting file.
DEVNET_PRIVATE_KEY=""
MAINNET_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# Optional deploy/initialize overrides (consumed by scripts/deploy.sh)
# -----------------------------------------------------------------------------
# Override the program id when initializing (otherwise resolved from
# Anchor.toml / target/idl). Set this when interacting with an already-deployed
# program from a different checkout.
# RYVO_PROGRAM_ID=""

# Authority that controls protocol config after `initialize`. Defaults to the
# deployer wallet. Useful for handing off to a multisig.
# RYVO_INITIAL_AUTHORITY=""

# Wallet that receives protocol fees. Defaults to the deployer wallet.
# RYVO_FEE_RECIPIENT=""

# JSON array of tokens to register at initialize time. Each entry needs an
# integer `id`, the SPL `mint`, and a `symbol`. Example for devnet USDC:
#   RYVO_ALLOWLIST_TOKENS='[{"id":1,"mint":"4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU","symbol":"USDC"}]'
# RYVO_ALLOWLIST_TOKENS=""

# Underlying USDC mint used by the yield-bearing bootstrap (mock-yield reserve
# + ryUSDC token entry). Defaults to canonical devnet USDC.
# RYVO_USDC_MINT=""

# Set to 1 to skip the yield-bearing bootstrap step at the end of deploy.sh.
# RYVO_SKIP_YIELD_BOOTSTRAP=0

# -----------------------------------------------------------------------------
# RPC endpoints (alternative to config/rpc.env)
# -----------------------------------------------------------------------------
# Either set a single override or one per network. The deploy script falls
# back to https://api.devnet.solana.com / https://api.mainnet-beta.solana.com
# if none of these are present.
# RYVO_RPC_URL=""
# RYVO_DEVNET_RPC_URL=""
# RYVO_MAINNET_RPC_URL=""

# -----------------------------------------------------------------------------
# Direct `solana program deploy` path (BLS-syscall programs)
# -----------------------------------------------------------------------------
# Set to 1 to bypass `anchor deploy` and use the Agave 4.x beta `solana` CLI
# directly. Required for the BLS-enabled program until anchor bundles a
# matching solana version. Auto-detected when scripts/deploy.sh sees the BLS
# syscall in the .so file, so you usually don't need to set this manually.
# RYVO_DEPLOY_WITH_SOLANA_CLI=0

# Path to the Agave 4.x beta solana binary used by deploy-bare-safe.sh.
# Defaults to ~/.local/share/agave-v4-beta/active_release/bin/solana.
# RYVO_SOLANA_BIN=""

# Tuning knobs for the direct deploy path.
# RYVO_DEPLOY_MAX_SIGN_ATTEMPTS=20
# RYVO_DEPLOY_COMPUTE_UNIT_PRICE=""
# RYVO_DEPLOY_SKIP_PREFLIGHT=0

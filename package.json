{
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "verify:ts": "tsc --noEmit --pretty false",
    "verify": "cargo fmt --all --check && cargo clippy -- -D warnings && anchor build -- --features custom-heap && npm run verify:ts",
    "verify:protocol": "npm run verify && npm run test:capacity",
    "verify:bls-local": "npm run test:bls-capacity",
    "verify:full": "npm run verify && npm run test:capacity && anchor test --skip-local-validator -- --features custom-heap",
    "test": "npm run test:shared",
    "test:shared": "ANCHOR_PROVIDER_URL=${ANCHOR_PROVIDER_URL:-http://127.0.0.1:8899} ANCHOR_WALLET=${ANCHOR_WALLET:-keys/devnet-deployer.json} ts-mocha -p tsconfig.json -t 1000000 tests/ryvo-protocol.test.ts",
    "test:bootstrap": "ANCHOR_PROVIDER_URL=${ANCHOR_PROVIDER_URL:-http://127.0.0.1:8899} ANCHOR_WALLET=${ANCHOR_WALLET:-keys/devnet-deployer.json} ts-mocha -p tsconfig.json -t 1000000 tests/bootstrap-isolated.test.ts",
    "test:capacity": "ts-mocha -p tsconfig.json tests/round-capacity.test.ts tests/unilateral-settlement-capacity.test.ts tests/multilateral-capacity.test.ts",
    "test:bls-capacity": "ANCHOR_PROVIDER_URL=${ANCHOR_PROVIDER_URL:-http://127.0.0.1:8899} ANCHOR_WALLET=${ANCHOR_WALLET:-keys/devnet-deployer.json} RYVO_RUN_BLS_CAPACITY=1 ts-mocha -p tsconfig.json -t 1000000 tests/bls-capacity-local.test.ts",
    "test:local:prepare": "./scripts/prepare-local-test-suite.sh",
    "deploy": "./scripts/deploy.sh",
    "deploy:devnet": "./scripts/deploy.sh --network=devnet",
    "deploy:mainnet": "./scripts/deploy.sh --network=mainnet",
    "colosseum:drain": "ts-node scripts/colosseum-drain-current.ts",
    "colosseum:basic": "ts-node scripts/colosseum-basic-setup.ts",
    "colosseum:fund": "ts-node scripts/colosseum-fund-wallets.ts",
    "colosseum:channels": "ts-node scripts/colosseum-channels-setup.ts",
    "colosseum:bundle": "ts-node scripts/colosseum-bundle-for-demo.ts",
    "setup:wallet": "./scripts/setup-wallet.sh",
    "demo:ryvo-protocol": "./scripts/ryvo-protocol-demo.sh",
    "benchmarks:generate": "ts-node scripts/export-benchmarks.ts",
    "benchmarks:docs": "ts-node scripts/export-benchmarks.ts --docs-only"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@noble/curves": "^1.9.7",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^24.9.1",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.3"
  }
}

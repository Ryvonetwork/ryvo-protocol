  | TokenIdAlreadyInUse
  | UnauthorizedTokenRegistration
  | InvalidTokenId
  | InvalidTokenSymbol
  | InvalidTokenDecimals
  | TokenRegistryFull
  | InvalidTokenMint
  | InsufficientLockedBalance
  | NoChannelUnlockPending
  | InvalidAuthorizedSigner
  | NoAuthorizedSignerUpdatePending

/// Pending config authority accepts the handoff.
handler accept_config_authority : State.Active -> State.Closed {
  auth pending_authority
  // TODO: Add guard clause
  // TODO: Add effect block
  accounts {
    global_config : writable, pda [global_config]
    pending_authority : signer
  }
}

/// Pending token registry authority accepts the handoff.
handler accept_registry_authority : State.Active -> State.Closed {
  auth pending_authority
  // TODO: Add guard clause
  // TODO: Add effect block
  accounts {
    token_registry : token, writable, pda [token_registry]
    pending_authority : signer
  }
}

/// Cancel a pending withdrawal for a specific token.
handler cancel_withdrawal (token_id : U16) : State.Active -> State.Closed {
  auth owner
  // TODO: Add guard clause
  // TODO: Add effect block
  accounts {
    participant_account : writable, pda [participant_account]
    owner : signer, authority participant_account
  }
}

/// Create a token-specific channel from payer to payee. Must be called before any payment commitments are signed or settled. Payer signs and pays ~0.002 SOL rent. Ensures payees and facilitators never pay for creation.
handler create_channel (token_id : U16) (authorized_signer : U64) : State.Uninitialized -> State.Active {
  auth owner
  // TODO: Add guard clause
  // TODO: Add effect block
  accounts {
    token_registry : token, pda [token_registry]
    payer_account : pda [payer_account]
    payee_account : pda [payee_account]
    channel_state : writable, pda [channel_state]
    owner : signer, writable, authority payer_account
    payee_owner : signer
    system_program : program
  }
}

/// Deposit tokens into the vault (credits signer's vault).
handler deposit (token_id : U16) (amount : U64) : State.Active -> State.Closed {
  auth owner
  // TODO: Add guard clause
  // TODO: Add effect block
  // TODO: Add transfers block for token transfer between owner_token_account and vault_token_account
  accounts {
    token_registry : token, pda [token_registry]
    global_config : pda [global_config]
    participant_account : writable, pda [participant_account]
    owner_token_account : token, writable
    vault_token_account : token, writable, pda [vault_token_account]
    owner : signer, authority participant_account
    token_program : program
  }
}

/// Deposit a registered token for multiple participants in one tx. Funder's ATA to vault; credits each recipient. amounts.len() must equal remaining_accounts (ParticipantAccounts). Max 16 recipients.
handler deposit_for (token_id : U16) (amounts : U64) : State.Active -> State.Active {
  auth funder
  // TODO: Add guard clause
  // TODO: Add effect block
  // TODO: Add transfers block for token transfer between funder_token_account and vault_token_account
  accounts {
    token_registry : token, pda [token_registry]
    global_config : pda [global_config]
    funder_token_account : token, writable
    vault_token_account : token, writable, pda [vault_token_account]
    funder : signer
    token_program : program
  }
}


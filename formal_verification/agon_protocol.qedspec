/// Initialize the protocol: creates GlobalConfig PDA. `chain_id` selects the immutable settlement domain and withdrawal timelock.
handler initialize (chain_id : U16) (fee_bps : U16) (registration_fee_lamports : U64) (initial_authority : U64) : State.Uninitialized -> State.Active {
  auth upgrade_authority
  // TODO: Add guard clause
  // TODO: Add effect block
  accounts {
    global_config : writable, pda [global_config]
    fee_recipient : readonly
    upgrade_authority : signer, writable
    program : readonly
    program_data : readonly
    system_program : program
  }
}


pda global_config ["global-config"]
pda token_registry ["token-registry"]
pda participant_account ["participant", owner]
pda payer_account ["participant", owner]
pda payee_account ["participant", owner]
pda channel_state ["channel-v2", participant_id, participant_id, token_id]
pda vault_token_account ["vault-token-account", token_id]

